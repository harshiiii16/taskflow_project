# ============================================================
# TaskFlow — Railway Environment Variables
# Copy these into your Railway service → Variables tab
# ============================================================

# ── JWT (generate a strong random secret) ───────────────────
# Run: openssl rand -hex 64
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_64_CHARS

# ── JWT expiry (milliseconds) ────────────────────────────────
JWT_EXPIRATION_MS=86400000

# ── Frontend URL (set AFTER you deploy the frontend) ─────────
FRONTEND_URL=https://YOUR_FRONTEND_RAILWAY_URL

# ── Spring profile ───────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── NOTE: Railway MySQL plugin auto-injects these: ───────────
# MYSQLHOST
# MYSQLPORT
# MYSQLDATABASE
# MYSQLUSER
# MYSQLPASSWORD
# (Do NOT set these manually — Railway sets them automatically)
